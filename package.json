{
  "name": "radicalkjax-blog",
  "version": "1.0.0",
  "description": "Personal website and blog of Kali Jackson (radicalkjax.com), built with Jekyll.",
  "private": true,
  "scripts": {
    "start": "bundle exec jekyll serve --host 0.0.0.0 --port 4000",
    "build": "bundle exec jekyll build",
    "build:prod": "JEKYLL_ENV=production bundle exec jekyll build",
    "clean": "rm -rf _site .jekyll-cache .sass-cache",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint assets/js --ext .js --fix",
    "lint:css": "stylelint 'assets/css/**/*.css' --fix",
    "format": "prettier --write '**/*.{js,css,md,yml,json}'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/radicalkjax/blog.git"
  },
  "keywords": [
    "jekyll",
    "blog",
    "github-pages",
    "personal-website"
  ],
  "author": "Kali Jackson <kali@radicalkjax.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/radicalkjax/blog/issues"
  },
  "homepage": "https://radicalkjax.com",
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.1.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^35.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
